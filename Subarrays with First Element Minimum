class Solution:
    def countSubarrays(self, arr):
        n = len(arr)
        stack = []
        result = 0
        
        for i in range(n):
            # Maintain increasing stack
            while stack and arr[stack[-1]] > arr[i]:
                idx = stack.pop()
                result += i - idx
            
            stack.append(i)
        
        # Remaining elements
        while stack:
            idx = stack.pop()
            result += n - idx
        
        return result
