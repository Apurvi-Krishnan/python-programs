class Solution:
	def preGreaterEle(self, arr):
		# code here
		stack = []
        result = []
        
        for x in arr:
            # Remove elements <= current
            while stack and stack[-1] <= x:
                stack.pop()
            
            # If stack is empty
            if not stack:
                result.append(-1)
            else:
                result.append(stack[-1])
            
            # Push current element
            stack.append(x)
        
        return result
