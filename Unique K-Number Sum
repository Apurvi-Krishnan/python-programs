class Solution:
    def combinationSum(self, n, k):
        # code here
        result = []
        
        def backtrack(start, path, total):
            # If valid combination found
            if len(path) == k:
                if total == n:
                    result.append(path[:])
                return
            
            # Try numbers from current start to 9
            for i in range(start, 10):
                # Prune if sum exceeds
                if total + i > n:
                    break
                
                path.append(i)
                backtrack(i + 1, path, total + i)
                path.pop()  # backtrack
        
        backtrack(1, [], 0)
        return result
        
